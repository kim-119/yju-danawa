# ============================================================
#  학교 도서관 크롤러 환경변수 템플릿
#  이 파일을 복사해서 .env 를 만드세요:  copy .env.example .env
#  그 후 LIB_USER_ID 와 LIB_USER_PASSWORD 만 본인 정보로 수정!
# ============================================================

# ── 필수: 본인 학번과 비밀번호 ──
LIB_USER_ID=본인학번
LIB_USER_PASSWORD=본인비밀번호

# ── 도서관 URL ──
LIB_LOGIN_URL=https://lib.yju.ac.kr
LIB_LOAN_URL=https://lib.yju.ac.kr/Cheetah/YJCL/MyLibrary/Lent

# ── Playwright 옵션 ──
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000

# ── 로그인 폼 셀렉터 (사이트 구조가 바뀌면 수정) ──
LIB_ID_SELECTOR=#formText input[name='loginId'], #formText input[id='loginId'], input[name='id'], input[name='userId']
LIB_PASSWORD_SELECTOR=#formText input[name='loginpwd'], #formText input[id='loginpwd'], input[name='password'], input[id*='password'], input[type='password']
LIB_SUBMIT_SELECTOR=#formText button[type='submit'], button[type='submit']:has-text('로그인'), input[type='submit']
LIB_LOAN_ROW_SELECTOR=table tbody tr
