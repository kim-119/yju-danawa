# ==============================================================
# Y-Danawa 외부 API 키 설정
# 이 파일을 .env로 복사하고 실제 API 키를 입력하세요
# 명령어: Copy-Item .env.example .env
# ==============================================================

# Kakao 도서 검색 API (https://developers.kakao.com/)
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# Aladin TTB API (https://www.aladin.co.kr/ttb/)
ALADIN_TTB_KEY=your_aladin_ttb_key_here

# Google Books API (https://console.cloud.google.com/)
GOOGLE_API_KEY=your_google_api_key_here

# Spring Boot <-> library-scraper gRPC
APP_GRPC_HOST=localhost
APP_GRPC_PORT=9090

# Shared fallback image URL (must be reachable)
PLACEHOLDER_IMAGE_URL=https://placehold.co/120x174?text=%EC%9D%B4%EB%AF%B8%EC%A7%80+%EC%97%86%EC%9D%8C
